{
  "api_key": {
    "description": "API Key",
    "type": "string",
    "default": ""
  },
  "api_base": {
    "description": "API 基础地址",
    "type": "string",
    "default": "https://api.tu-zi.com/v1"
  },
  "model": {
    "description": "模型名称",
    "type": "string",
    "default": "gpt-image-2"
  },
  "api_format": {
    "description": "images = /images/generations, chat = /chat/completions, auto = 先 images 后 chat",
    "type": "string",
    "default": "images"
  },
  "timeout": {
    "description": "请求超时（秒）",
    "type": "int",
    "default": 240
  }
}